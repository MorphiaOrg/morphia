[
  {
    "extension": "revapi.filter",
    "configuration": {
      "elements": {
        "exclude": [
          {
            "matcher": "java",
            "match": "@dev.morphia.annotations.internal.MorphiaInternal ^*;"
          },
          {
            "matcher": "java",
            "match": "@dev.morphia.annotations.internal.MorphiaExperimental ^*;"
          },
          {
            "matcher": "java-package",
            "match": "/.*\\.internal(\\..*)?/"
          },
          {
            "matcher": "java-package",
            "match": "/.*\\.experimental(\\..*)?/"
          },
          {
            "matcher": "java-package",
            "match": "/.*codec.*/"
          }
        ]
      }
    }
  }
]
